rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Administrator: ajarek2101@gmail.com (Firebase Authentication)
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'ajarek2101@gmail.com';
    }

    function isOwner() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    function isOwnerOnCreate() {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if isOwner() || isAdmin();
      allow create: if isOwnerOnCreate();
      allow update, delete: if isOwner() || isAdmin();
    }

    match /favorites/{favoriteId} {
      allow read: if isOwner() || isAdmin();
      allow create: if isOwnerOnCreate();
      allow update, delete: if isOwner() || isAdmin();
    }

    // Profile użytkowników (panel administratora)
    match /users/{userId} {
      // Własny profil – odczyt; admin – pełny dostęp
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
